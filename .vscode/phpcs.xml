<ruleset name="codespaces-grafting PHPCS">
  <description>Shared PHPCS ruleset for VS Code and CI.</description>

  <file>./</file>

  <arg name="extensions" value="php"/>

  <exclude-pattern>*/third-party/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/.devcontainer/*</exclude-pattern>
  <exclude-pattern>*/.vscode/*</exclude-pattern>
  <exclude-pattern>*/languages/*</exclude-pattern>

  <rule ref="WordPress"/>

  <rule ref="./.vscode/phpcs-standard/I18nly/Sniffs/Files/FileLengthSniff.php">
    <properties>
      <property name="lineLimit" value="400"/>
      <property name="absoluteLineLimit" value="700"/>
    </properties>
  </rule>
</ruleset>
