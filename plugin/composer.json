{
  "_comment": [
    "SPDX-FileCopyrightText: 2026 Eric van der Vlist <vdv@dyomedea.com>",
    "SPDX-License-Identifier: GPL-3.0-or-later"
  ],
  "name": "evlist/wp-i18nly-plugin-runtime",
  "description": "Runtime dependencies for the i18nly WordPress plugin.",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=8.0",
    "gettext/gettext": "^5.7",
    "mck89/peast": "^1.17"
  },
  "autoload": {
    "psr-4": {
      "WP_I18nly\\": "includes/WP_I18nly/"
    },
    "classmap": [
      "includes/"
    ],
    "exclude-from-classmap": [
      "/includes/WP_I18nly/"
    ]
  },
  "config": {
    "vendor-dir": "third-party/vendor",
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true
    }
  }
}